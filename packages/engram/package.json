  },
  "homepage": "https://github.com/MateoKnox/engram",
  "bugs": {
    "url": "https://github.com/MateoKnox/engram/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
