{
  "name": "@MateoKnox/engram",
  "version": "0.1.0",
  "description": "The Agent Memory Engine — structured, layered, decaying memory for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/*.test.js",
